# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/relay_e

# Cache
REDIS_URL=redis://localhost:6379

# LLM Providers (use ANTHROPIC_API_KEY for prod, leave blank for fully-local Ollama)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
VOYAGE_API_KEY=

# Local LLM (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_CHAT_MODEL=llama3.2
LOCAL_EMBED_MODEL=nomic-embed-text

# Default model routing
DEFAULT_PROVIDER=anthropic
DEFAULT_CHAT_MODEL=claude-sonnet-4-6
DEFAULT_FAST_MODEL=claude-haiku-4-5-20251001
DEFAULT_EMBED_MODEL=voyage-3

# API
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# Auth (dev mode uses static API keys)
DEV_API_KEY=sk_dev_local_change_me
