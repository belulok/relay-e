{
  "name": "relay-e",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Multi-tenant context-aware AI orchestration engine. Skills, tools, and a context resolver in front of any LLM (Anthropic, OpenAI, or local Ollama).",
  "license": "MIT",
  "author": "Sebastian Belulok",
  "homepage": "https://github.com/belulok/relay-e#readme",
  "bugs": {
    "url": "https://github.com/belulok/relay-e/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/belulok/relay-e.git"
  },
  "keywords": [
    "ai",
    "llm",
    "agent",
    "orchestration",
    "context-engine",
    "rag",
    "mcp",
    "anthropic",
    "openai",
    "ollama",
    "hono",
    "drizzle",
    "pgvector"
  ],
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:db": "RELAY_E_TEST_DB=1 vitest run",
    "openapi:export": "bash scripts/export-openapi.sh",
    "db:generate": "npm run generate -w @relay-e/db",
    "db:migrate": "npm run migrate -w @relay-e/db",
    "db:studio": "npm run studio -w @relay-e/db",
    "stack:up": "docker compose up -d",
    "stack:down": "docker compose down",
    "stack:logs": "docker compose logs -f",
    "stack:reset": "docker compose down -v && docker compose up -d",
    "worker": "npm run worker -w @relay-e/queue"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
